# Copy to .env and adjust. All values below are the defaults.

# Chunking: fixed | sentence
RAG_KB_CHUNK_STRATEGY=sentence
RAG_KB_CHUNK_SIZE=800
RAG_KB_CHUNK_OVERLAP=120

# Embeddings: hash | sentence-transformers | openai
RAG_KB_EMBEDDER=hash
RAG_KB_EMBEDDING_DIM=512
# RAG_KB_ST_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_KB_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
RAG_KB_TOP_K=4
RAG_KB_CANDIDATE_POOL=20
RAG_KB_FUSION_WEIGHT=0.5
RAG_KB_RRF_K=60

# Answer synthesis: offline | openai | anthropic
RAG_KB_LLM_PROVIDER=offline
# RAG_KB_OPENAI_CHAT_MODEL=gpt-4o-mini
# RAG_KB_ANTHROPIC_MODEL=claude-sonnet-4-5

# Only needed when a cloud backend is selected (read by the vendor SDKs).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
