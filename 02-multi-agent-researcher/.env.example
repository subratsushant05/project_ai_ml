# Copy to .env and adjust. Every value below is the default: the project
# runs fully offline with no keys at all.

# Chat model backend: offline | openai | anthropic
AGENT_MODEL_PROVIDER=offline
# Provider-specific model name (blank = provider default)
AGENT_MODEL_NAME=

# Search backend: offline | tavily
AGENT_SEARCH_PROVIDER=offline
# Corpus used by the offline search tool
#AGENT_CORPUS_PATH=sample_data/corpus.json

# Pipeline tuning
AGENT_SEARCH_TOP_K=3
AGENT_NUM_SUB_QUESTIONS=3
AGENT_QUALITY_THRESHOLD=8.0
AGENT_MAX_REVISIONS=1
AGENT_REQUIRE_APPROVAL=false

# Only needed for hosted providers (install the matching optional extra):
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#TAVILY_API_KEY=
